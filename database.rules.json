{"rules":{"chats":{"$conversationId":{"messages":{".read":"auth != null && ($conversationId.contains(auth.uid))",".write":"auth != null && ($conversationId.contains(auth.uid))","$messageId":{"text":{".validate":"newData.isString() && newData.val().length() <= 1000"},"senderId":{".validate":"newData.val() === auth.uid"}}}}},"conversations":{"$userId":{".read":"auth != null && auth.uid === $userId",".write":"auth != null && auth.uid === $userId"}},"presence":{"$userId":{".read":"auth != null",".write":"auth != null && auth.uid === $userId"}},"$other":{".read":false,".write":false}}}