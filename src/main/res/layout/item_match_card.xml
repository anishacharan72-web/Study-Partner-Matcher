<?xml version="1.0" encoding="utf-8"?>
<!--
  Match card: white surface, 20dp corner radius, 16dp padding.
  Avatar (32dp) | Name (20sp SemiBold) | Institution (12sp muted)
  Subject tags (Lavender pills) | Compatibility score badge (Coral)
  Accept / Decline buttons (min 44dp touch targets)
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_12"
    app:cardCornerRadius="@dimen/radius_card"
    app:cardElevation="@dimen/card_elevation"
    app:cardBackgroundColor="@color/surface_white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/card_padding">

        <!-- Avatar -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/ivAvatar"
            android:layout_width="@dimen/avatar_sm"
            android:layout_height="@dimen/avatar_sm"
            android:src="@drawable/ic_avatar_placeholder"
            app:civ_border_width="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:contentDescription="Partner avatar" />

        <!-- Name -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_xl"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="@id/ivAvatar"
            app:layout_constraintStart_toEndOf="@id/ivAvatar"
            app:layout_constraintEnd_toStartOf="@id/tvScore"
            android:layout_marginStart="@dimen/space_12"
            android:contentDescription="Partner name" />

        <!-- Institution -->
        <TextView
            android:id="@+id/tvInstitution"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/text_muted"
            android:fontFamily="sans-serif"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/tvName"
            app:layout_constraintStart_toEndOf="@id/ivAvatar"
            app:layout_constraintEnd_toStartOf="@id/tvScore"
            android:layout_marginStart="@dimen/space_12"
            android:layout_marginTop="@dimen/space_4"
            android:contentDescription="Partner institution" />

        <!-- Compatibility Score Badge (Warm Coral, white text) -->
        <TextView
            android:id="@+id/tvScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/space_12"
            android:paddingVertical="@dimen/space_4"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/surface_white"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_tag_selected"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:contentDescription="Compatibility score" />

        <!-- Subject Chips -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupSubjects"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/ivAvatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/space_12"
            app:chipSpacingHorizontal="@dimen/space_8"
            android:contentDescription="Study subjects" />

        <!-- Accept Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAccept"
            style="@style/Widget.StudyMatcher.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="@dimen/min_touch_target"
            android:text="@string/accept"
            app:layout_constraintTop_toBottomOf="@id/chipGroupSubjects"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnDecline"
            android:layout_marginTop="@dimen/space_16"
            android:layout_marginEnd="@dimen/space_8"
            android:contentDescription="Accept match button" />

        <!-- Decline Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDecline"
            style="@style/Widget.StudyMatcher.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="@dimen/min_touch_target"
            android:text="@string/decline"
            app:layout_constraintTop_toBottomOf="@id/chipGroupSubjects"
            app:layout_constraintStart_toEndOf="@id/btnAccept"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/space_16"
            android:contentDescription="Decline match button" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
