<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_blush">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/deep_navy"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="52dp"
            android:paddingBottom="48dp">

            <!-- Avatar circle -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivProfilePhoto"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:src="@drawable/ic_avatar_placeholder"
                app:civ_border_width="3dp"
                app:civ_border_color="@color/warm_coral" />

            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/surface_white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/tvProfileEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#AAAACC"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <!-- Rating stars -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical">

                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_star" />
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_star" />
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_star" />
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_star_outline" />
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_star_outline" />

                <TextView
                    android:id="@+id/tvRatingText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New member"
                    android:textColor="#AAAACC"
                    android:textSize="13sp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Info card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:layout_marginTop="-20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/surface_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Institution row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_profile" android:alpha="0.6" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Institution" android:textSize="11sp" android:textColor="@color/text_muted" />
                        <TextView android:id="@+id/tvInstitution"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Not set" android:textSize="15sp" android:textColor="@color/text_primary"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/background_blush" android:layout_marginVertical="14dp" />

                <!-- Study goal row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_matches" android:alpha="0.6" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Study Goal" android:textSize="11sp" android:textColor="@color/text_muted" />
                        <TextView android:id="@+id/tvStudyGoal"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Not set" android:textSize="15sp" android:textColor="@color/text_primary"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/background_blush" android:layout_marginVertical="14dp" />

                <!-- Mode preference row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_chat" android:alpha="0.6" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Mode Preference" android:textSize="11sp" android:textColor="@color/text_muted" />
                        <TextView android:id="@+id/tvModePreference"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Not set" android:textSize="15sp" android:textColor="@color/text_primary"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/background_blush" android:layout_marginVertical="14dp" />

                <!-- Subjects row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="top">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_matches" android:alpha="0.6"
                        android:layout_marginTop="4dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="My Subjects" android:textSize="11sp" android:textColor="@color/text_muted" />
                        <TextView android:id="@+id/tvSubjectsList"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tap 'Update Subjects' to add"
                            android:textSize="14sp" android:textColor="@color/text_primary"
                            android:lineSpacingMultiplier="1.4"
                            android:visibility="gone" />
                        <TextView
                            android:id="@+id/tvNoSubjects"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="None added yet"
                            android:textSize="14sp" android:textColor="@color/text_muted"
                            android:textStyle="italic" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditProfile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Edit Profile"
                android:backgroundTint="@color/warm_coral"
                android:textColor="@color/surface_white"
                app:cornerRadius="26dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdateSubjects"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Update Subjects"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/lavender"
                android:textColor="@color/deep_navy"
                app:cornerRadius="26dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignOut"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Sign Out"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/surface_white"
                android:textColor="@color/warm_coral"
                app:strokeColor="@color/warm_coral"
                app:strokeWidth="1.5dp"
                app:cornerRadius="26dp"
                android:layout_marginBottom="100dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
