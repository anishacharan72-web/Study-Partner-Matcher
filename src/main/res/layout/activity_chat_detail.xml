<?xml version="1.0" encoding="utf-8"?>
<!-- Chat detail activity: Warm Coral toolbar, message RecyclerView, input bar -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_blush">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/top_bar_height"
        android:background="@color/deep_navy"
        app:titleTextColor="@color/surface_white"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/surface_white"
        app:menu="@menu/menu_chat_detail"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Messages RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="@dimen/space_8"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/inputBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="Chat messages" />

    <!-- Input bar -->
    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface_white"
        android:elevation="4dp"
        android:padding="@dimen/space_8"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Character counter (shows near limit) -->
        <TextView
            android:id="@+id/tvCharCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:textSize="@dimen/text_xs"
            android:textColor="@color/text_muted"
            android:fontFamily="sans-serif"
            android:visibility="gone"
            android:layout_marginEnd="@dimen/space_8"
            android:layout_marginBottom="@dimen/space_4" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/chat_input_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input_field">

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="@string/message_hint"
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_base"
                android:fontFamily="sans-serif"
                android:background="@null"
                android:padding="@dimen/space_12"
                android:maxLength="1000"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="4"
                android:contentDescription="Message input field" />

            <!-- Send button: Warm Coral, 22dp icon -->
            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="@dimen/min_touch_target"
                android:layout_height="@dimen/min_touch_target"
                android:src="@drawable/ic_send"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/warm_coral"
                android:enabled="false"
                android:padding="@dimen/space_8"
                android:contentDescription="Send message button" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
